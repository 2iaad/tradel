		{
			"x": 688.323160417986,
			"y": -5945.062374453851,
			"rotation": 0,
			"isLocked": false,
			"opacity": 1,
			"meta": {},
			"id": "shape:3eELKf0GdvCGxgidARBeG",
			"type": "text",
			"props": {
				"color": "yellow",
				"size": "s",
				"w": 1032.0309407457728,
				"font": "sans",
				"textAlign": "start",
				"autoSize": false,
				"scale": 1.5653868679436092,
				"richText": {
					"type": "doc",
					"attrs": {
						"dir": "auto"
					},
					"content": [
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"marks": [
										{
											"type": "bold"
										}
									],
									"text": "a. Decide orchestration and confirm DB reachability"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "hardBreak",
									"attrs": {
										"dir": "auto"
									}
								},
								{
									"type": "text",
									"text": "You have a Postgres Dockerfile + "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "link",
											"attrs": {
												"href": "http://init.sh",
												"target": "_blank",
												"rel": "noopener noreferrer nofollow",
												"class": null
											}
										}
									],
									"text": "init.sh"
								},
								{
									"type": "text",
									"text": " but no docker-compose.yml."
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "Add one that runs the Postgres service and publishes the port to the host (e.g. "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "5432:5432"
								},
								{
									"type": "text",
									"text": ")."
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "Prisma migrations run from your host (or container) and need a reachable port. Confirm the credentials/db name in "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "link",
											"attrs": {
												"href": "http://init.sh",
												"target": "_blank",
												"rel": "noopener noreferrer nofollow",
												"class": null
											}
										},
										{
											"type": "code"
										}
									],
									"text": "init.sh"
								},
								{
									"type": "text",
									"text": " match what your "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "DATABASE_URL"
								},
								{
									"type": "text",
									"text": " will use. Nothing Prisma works until the DB is actually connectable."
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							}
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							}
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"marks": [
										{
											"type": "bold"
										}
									],
									"text": "b. Install Prisma"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "hardBreak",
									"attrs": {
										"dir": "auto"
									}
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "npm i -D prisma"
								},
								{
									"type": "text",
									"text": " and "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "npm i @prisma/client"
								},
								{
									"type": "text",
									"text": ". Dev dep is the CLI, the other is the runtime client your code imports."
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"marks": [
										{
											"type": "bold"
										}
									],
									"text": "3c. Initialize Prisma without clobbering your env"
								},
								{
									"type": "hardBreak",
									"attrs": {
										"dir": "auto"
									}
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "npx prisma init"
								},
								{
									"type": "text",
									"text": " creates "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "prisma/schema.prisma"
								},
								{
									"type": "text",
									"text": " and a "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": ".env"
								},
								{
									"type": "text",
									"text": ". You already have env handling via "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "@nestjs/config"
								},
								{
									"type": "text",
									"text": " + Zod, so delete or ignore the "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": ".env"
								},
								{
									"type": "text",
									"text": " it generates if it conflicts. Key point: the Prisma CLI reads "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "DATABASE_URL"
								},
								{
									"type": "text",
									"text": " from a "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": ".env"
								},
								{
									"type": "text",
									"text": " file itself (it does not go through your ConfigModule) for migrations. So "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "DATABASE_URL"
								},
								{
									"type": "text",
									"text": " must exist in a file the CLI can read, matching 3a's credentials."
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							}
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							}
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"marks": [
										{
											"type": "bold"
										}
									],
									"text": "d. Configure datasource and generator"
								},
								{
									"type": "hardBreak",
									"attrs": {
										"dir": "auto"
									}
								},
								{
									"type": "text",
									"text": "In "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "schema.prisma"
								},
								{
									"type": "text",
									"text": ", set "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "datasource db"
								},
								{
									"type": "text",
									"text": " provider to "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "postgresql"
								},
								{
									"type": "text",
									"text": ", "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "url = env(\"DATABASE_URL\")"
								},
								{
									"type": "text",
									"text": ", and confirm the "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "generator client"
								},
								{
									"type": "text",
									"text": ". This has to be correct before any migration or model definition is meaningful."
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							}
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							}
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"marks": [
										{
											"type": "bold"
										}
									],
									"text": "e. Define the User model"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							}
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "prisma"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "model User {   id                 String   @id @default(uuid())   email              String   @unique   passwordHash       String   hashedRefreshToken String?   createdAt          DateTime @default(now())   updatedAt          DateTime @updatedAt }"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "Comes after datasource config because the migration in the next step reads this."
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"marks": [
										{
											"type": "bold"
										}
									],
									"text": "3f. Run the first migration"
								},
								{
									"type": "hardBreak",
									"attrs": {
										"dir": "auto"
									}
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "npx prisma migrate dev --name init"
								},
								{
									"type": "text",
									"text": " with the DB running. This creates the SQL, applies it, and generates the client in one go. If it hangs or errors, it is almost always 3a (port not published, or credentials mismatch)."
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"marks": [
										{
											"type": "bold"
										}
									],
									"text": "3g. Build PrismaService"
								},
								{
									"type": "hardBreak",
									"attrs": {
										"dir": "auto"
									}
								},
								{
									"type": "text",
									"text": "A service extending "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "PrismaClient"
								},
								{
									"type": "text",
									"text": ", connecting in "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "onModuleInit"
								},
								{
									"type": "text",
									"text": ". Depends on the client being generated in 3f."
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "ts"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "@Injectable() export class PrismaService extends PrismaClient implements OnModuleInit {   async onModuleInit() {     await this.$connect();   } }"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"marks": [
										{
											"type": "bold"
										}
									],
									"text": "3h. Build global PrismaModule"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "ts"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "@Global() @Module({   providers: [PrismaService],   exports: [PrismaService], }) export class PrismaModule {}"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "@Global()"
								},
								{
									"type": "text",
									"text": " so the UsersModule (step 4) and others inject "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "PrismaService"
								},
								{
									"type": "text",
									"text": " without re-importing."
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"marks": [
										{
											"type": "bold"
										}
									],
									"text": "3i. Wire into AppModule"
								},
								{
									"type": "hardBreak",
									"attrs": {
										"dir": "auto"
									}
								},
								{
									"type": "text",
									"text": "Add "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "PrismaModule"
								},
								{
									"type": "text",
									"text": " to "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "AppModule"
								},
								{
									"type": "text",
									"text": " imports, delete the "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "// TODO: add prisma module"
								},
								{
									"type": "text",
									"text": " comment."
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"marks": [
										{
											"type": "bold"
										}
									],
									"text": "3j. Verify"
								},
								{
									"type": "hardBreak",
									"attrs": {
										"dir": "auto"
									}
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "npx prisma studio"
								},
								{
									"type": "text",
									"text": " to confirm the table exists, or a throwaway query in a service. Once this passes, step 4 (UsersModule) has something concrete to build against."
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "The one thing that bites people here is 3c: the CLI not reading your Zod-validated config. If migrations fail with a missing "
								},
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "DATABASE_URL"
								},
								{
									"type": "text",
									"text": " while your app boots fine, that mismatch is the cause."
								}
							]
						}
					]
				}
			},
			"parentId": "page:page",
			"index": "b1JKzv3DG",
			"typeName": "shape"
		},
