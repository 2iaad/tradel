# Frontend environment variables (Next.js).
# Copy to `.env.local` and fill in. `.env.local` is gitignored; this file is the
# committed template. Only NEXT_PUBLIC_* vars are exposed to browser code.

# Backend API origin (no trailing slash, no /api — the client appends /api).
# dev: http://localhost:3000   prod: your deployed backend URL.
NEXT_PUBLIC_API_URL=http://localhost:3000

# React Scan render-profiling overlay. Set to 1 to enable in dev. Leave unset off.
NEXT_PUBLIC_REACT_SCAN=