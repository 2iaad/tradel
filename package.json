{
  "name": "tradel-homepage",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev --host 0.0.0.0",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview --host 0.0.0.0",
    "serve": "node scripts/serve.mjs",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "test": "playwright test",
    "test:e2e": "playwright test tests/e2e",
    "test:visual": "playwright test tests/visual"
  },
  "dependencies": {
    "astro": "7.1.1",
    "gsap": "3.15.0",
    "lenis": "1.3.25",
    "swiper": "14.0.5"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@playwright/test": "1.61.1",
    "pixelmatch": "7.2.0",
    "pngjs": "7.0.0",
    "typescript": "6.0.3"
  }
}
